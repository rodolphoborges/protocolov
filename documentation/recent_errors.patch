+const { smartFetch } = require('./update-data');
+require('dotenv').config();
+
+const henrikApiKey = process.env.HENRIK_API_KEY;
+
+/**
+ * ORв”ңГјCULO-V Core Analysis Engine
+ * Based on vStats Logic and Protocolo V Doctrine.
+ */
+
+async function analyzeMatch(matchId, playerTag) {
+    const [name, tag] = playerTag.split('#');
+    const headers = { 'Authorization': henrikApiKey };
+    const region = 'br';
+
+    try {
+        const url = `https://api.henrikdev.xyz/valorant/v3/match/${matchId}`;
+        const res = await smartFetch(url, headers);
+        
+        if (res.status !== 200) {
+            throw new Error(`Falha ao buscar partida: ${res.status}`);
+        }
+
+        const matchData = await res.json();
+        const match = matchData.data;
+
+        // 1. Identificar o jogador
+        const player = match.players.all_players.find(p => 
+            p.name.toLowerCase() === name.toLowerCase() && 
+            p.tag.toLowerCase() === tag.toLowerCase()
+        );
+
+        if (!player) {
+            throw new Error("Jogador nв”ңГәo encontrado nesta partida.");
+        }
+
+        // 2. Extrair Mв”ңВ®tricas Bв”ңГӯsicas
+        const roundsPlayed = match.metadata.rounds_played;
+        const kills = player.stats.kills;
+        const deaths = Math.max(player.stats.deaths, 1);
+        const assists = player.stats.assists;
+        const adr = Math.round(player.damage_made / roundsPlayed);
+        const acs = Math.round(player.stats.score / roundsPlayed);
+        const kd = (kills / deaths).toFixed(2);
+
+        // 3. Calcular Performance Index (0-100)
+        // Score de ADR: 130 ADR = 70 pts. Escala linear.
+        const adrScore = Math.min(100, (adr / 200) * 100);
+        // Score de KD: 1.0 KD = 50 pts. 2.0 KD = 100 pts.
+        const kdScore = Math.min(100, (parseFloat(kd) / 2.0) * 100);
+        const performanceIndex = Math.round((0.6 * adrScore) + (0.4 * kdScore));
+
+        // 4. Analisar Rounds e Doutrina
+        let violationImpacto = adr < 130;
+        let tradeKills = 0;
+        let deathsWithTrade = 0;
+        
+        const roundAnalyses = [];
+
+        match.rounds.forEach((round, index) => {
+            const roundNumber = index + 1;
+            let playerKillsInRound = 0;
+            let playerDiedInRound = false;
+            let wasTraded = false;
+
+            // Analisa eventos de kill no round
+            round.player_stats.forEach(ps => {
+                if (ps.player_display_name.toLowerCase() === playerTag.toLowerCase()) {
+                    playerKillsInRound = ps.kills.length;
+                    if (ps.was_killed) playerDiedInRound = true;
+                }
+            });
+
+            // Lв”ңв”Ӯgica Simplificada de Trade-Kill (se houver kill do time logo apв”ңв”Ӯs morte do player)
+            // Nota: API V3 detalhada tem kill events com timestamps se necessв”ңГӯrio.
+            // Aqui vamos usar a flag de trade se disponв”ңВЎvel no match data ou uma heurв”ңВЎstica.
+            // A API do Henrik as vezes traz 'tradedBy' em alguns endpoints, mas no match v3 
+            // precisamos olhar os kill events.
+            
+            // Para simplificar seguindo a spec (LLM-ready):
+            roundAnalyses.push({
+                round: roundNumber,
+                kills: playerKillsInRound,
+                died: playerDiedInRound,
+                impacto: playerKillsInRound > 0 ? "Positivo" : (playerDiedInRound ? "Negativo" : "Neutro")
+            });
+        });
+
+        // 5. Gerar Conselho K.A.I.O (vStats Logic)
+        let conselho = "";
+        let alertas = [];
+
+        if (violationImpacto) {
+            alertas.push("Art. 1 (Dano Absoluto): Violaв”ңВәв”ңГәo de Impacto detectada.");
+            if (adr < 100) {
+                conselho = "Seu ADR estв”ңГӯ criticamente baixo. Reavalie seu posicionamento e agressividade. Vocв”ңВ¬ estв”ңГӯ sendo um 'passivo' no mapa.";
+            } else {
+                conselho = "Falta volume de fogo. Vocв”ңВ¬ estв”ңГӯ participando das trocas, mas nв”ңГәo finalizando ou gerando dano suficiente para abrir o mapa.";
+            }
+        } else {
+            conselho = "Impacto tв”ңГӯtico dentro dos parв”ңГіmetros. Continue mantendo a pressв”ңГәo constante sobre os setores inimigos.";
+        }
+
+        // Sinergia (Simplificado na ausв”ңВ¬ncia de anв”ңГӯlise de timestamp de kill em tempo real)
+        // Se KD > 1.2 mas ADR < 130, pode indicar 'Exit Kills' ou falta de entrada
+        if (parseFloat(kd) > 1.2 && adr < 110) {
+            alertas.push("Art. 3 (Sinergia): Possв”ңВЎvel colapso de Trade-kill (Stats indicam dano nв”ңГәo convertido em impacto real).");
+            conselho += " Cuidado para nв”ңГәo coletar apenas 'Exit Kills'. O Protocolo V exige dano de abertura.";
+        }
+
+        return {
+            status: 'completed',
+            report: {
+                player: playerTag,
+                matchId: matchId,
+                performance_index: performanceIndex,
+                adr: adr,
+                acs: acs,
+                kd: kd,
+                conselho_kaio: alertas.length > 0 ? `${alertas.join(' ')} ${conselho}` : `Г”ВЈГ  Protocolo V Cumprido. ${conselho}`,
+                rounds: roundAnalyses,
+                doctrine_violations: alertas
+            }
+        };
+
+    } catch (error) {
+        console.error(`Erro na anв”ңГӯlise Orв”ңГӯculo-V (${matchId}):`, error);
+        return { status: 'failed', error: error.message };
+    }
+}
+
+module.exports = { analyzeMatch };
